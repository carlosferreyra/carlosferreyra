#import "@preview/silver-dev-cv:{{ version }}": *

// scripts/resume_pdf.py resolves one labeled profile to an ephemeral JSON file.
#let r = json("../" + sys.inputs.at("data"))
#let info = r.personalInfo
#let summary = r.at("summary", default: info.summary)

// A section renders only if present and non-empty in the resolved resume.
#let has(key) = key in r and r.at(key).len() > 0

#show: cv.with(
  font-type: "PT Serif",
  continue-header: "false",
  name: info.name,
  address: info.location,
  lastupdated: "true",
  pagecount: "true",
  date: datetime.today().display("[year]-[month]-[day]"),
  contacts: r.links.map(l => (text: l.label, link: l.url)),
)

#section[About Me]
#descript[#summary]
#sectionsep

#if has("experience") {
  section("Experience")
  for exp in r.experience {
    job(
      position: exp.title,
      institution: [#exp.company],
      location: exp.at("location", default: info.location),
      date: exp.period,
      description: [#for h in exp.highlights [- #h]],
    )
  }
  sectionsep
}

#if has("skills") {
  section("Skills")
  for group in r.skills {
    oneline-title-item(title: group.category, content: [#group.items.join(", ")])
  }
  sectionsep
}

#if has("projects") {
  section("Projects")
  for proj in r.projects {
    project(title: [#link(proj.url)[#proj.name]], date: [], description: [#proj.description])
    v(0.5em)
  }
  sectionsep
}

#if has("education") {
  section("Education")
  for edu in r.education {
    education(
      institution: [#edu.institution],
      major: [#edu.degree],
      date: edu.period,
      location: edu.location,
    )
  }
  sectionsep
}

#if has("certifications") {
  section("Certifications")
  for cert in r.certifications {
    [#oneline-title-item(title: str(cert.year), content: [#link(cert.url)[#cert.name]])]
  }
}

#set document(author: info.name, title: info.name + " - Resume")
