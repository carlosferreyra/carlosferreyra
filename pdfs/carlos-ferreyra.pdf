<!doctype html>
<html>
  <head lang="en">
    <meta charset="utf-8" />
    <title>Typst</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="prefetch" href="/assets/font-derived/font-index.mpk" />
    <link rel="prefetch" href="/assets/font-derived/font-previews.json" />
    <link rel="prefetch" href="/assets/font-derived/font-previews.png" />
    <link rel="manifest" href="/assets/site.webmanifest" />
    <meta name="theme-color" content="#eff0f3" />
    <style>
      body {
        background: #eff0f3;
        height: 100%;
        width: 100%;
      }

      .app-root-dummy {
        width: calc(100% - 64px);
        height: calc(100% - 40px);
        position: absolute;
        bottom: 0px;
        right: 0px;
        background: rgba(253, 253, 253, 1);
        color: rgba(25, 24, 31, 1);
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0px 4px 12px rgba(89, 85, 101, 0.2);
        font-size: 13px;
        font-family: Inter, sans-serif;
        border-top-left-radius: 6px;
        box-sizing: border-box;
      }

      :root[data-theme="dark"],
      :root[data-theme="christmas"] {
        background: #2a2934;
      }

      :root[data-theme="start23"] {
        background: #2e2934;
      }

      :root[data-theme="ubuntu"] {
        background: #060305;
      }

      :root[data-theme="dark"] .app-root-dummy,
      :root[data-theme="start23"] .app-root-dummy,
      :root[data-theme="ubuntu"] .app-root-dummy,
      :root[data-theme="christmas"] .app-root-dummy {
        background: rgba(25, 24, 31, 1);
        color: rgba(253, 253, 253, 1);
        box-shadow: none;
        border: 1px solid rgba(59, 58, 72, 1);
      }

      :root[data-theme="ubuntu"] .app-root-dummy {
        background: #191217;
      }

      @media (prefers-color-scheme: dark) {
        :root[data-theme="system"] {
          background: #2a2934;
        }

        :root[data-theme="system"] .app-root-dummy {
          background: rgba(25, 24, 31, 1);
          color: rgba(253, 253, 253, 1);
          box-shadow: none;
          border: 1px solid rgba(59, 58, 72, 1);
        }
      }
    </style>
    <script>
      try {
        const settingsStr = window.localStorage.getItem("global-settings")
        if (settingsStr) {
          const settings = JSON.parse(settingsStr)
          if (settings && settings.theme) {
            document.documentElement.setAttribute("data-theme", settings.theme)
          }
        }
      } catch {
        // do not retrieve settings if we can't
      }

      if (Array.prototype.findLast == undefined) {
        Array.prototype.findLast = (predicate) => {
          if (typeof predicate !== "function") {
            throw new TypeError("predicate must be a function")
          }

          const list = Object(this)
          const length = list.length >>> 0
          let value

          for (let i = length - 1; i >= 0; i--) {
            value = list[i]
            if (predicate.call(this, value, i, list)) {
              return value
            }
          }
          return undefined
        }
      }
    </script>
    <script type="module" crossorigin src="/assets/index-DyMsjo2f.js"></script>
    <link rel="stylesheet" crossorigin href="/assets/index-jNGYQXXt.css">
  </head>

  <body>
    <div id="app-root">
      <div class="app-root-dummy"></div>
    </div>
  </body>
</html>
