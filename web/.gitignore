# build output
dist/
.output/

# dependencies
node_modules/

# bun is the canonical package manager — keep bun.lock, ignore other locks
# so an accidental `npm install` / `pnpm install` / `yarn install` does not drift.
package-lock.json
pnpm-lock.yaml
yarn.lock

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# astro cache
.astro/
