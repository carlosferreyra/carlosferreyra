---
import Section from '~/components/Section.astro';
import { t, type Locale } from '~/i18n';
import { resume } from '~/lib/resume';

interface Props {
	locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<Section id="certifications" eyebrow="05" title={dict.sections.certifications}>
	<ul class="grid md:grid-cols-2 gap-3">
		{resume.certifications.map((cert) => (
			<li class="border border-border-muted bg-elev p-4 hover:border-accent transition-colors">
				<a
					href={cert.url}
					target="_blank"
					rel="noopener noreferrer"
					class="block"
				>
					<p class="font-mono text-xs text-accent mb-1">{cert.year}</p>
					<p class="text-fg text-sm group-hover:text-accent">{cert.name}</p>
				</a>
			</li>
		))}
	</ul>
</Section>
