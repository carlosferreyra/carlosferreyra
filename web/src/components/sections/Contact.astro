---
import Button from '~/components/Button.astro';
import Section from '~/components/Section.astro';
import { t, type Locale } from '~/i18n';
import { linkById, resume } from '~/lib/resume';

interface Props {
	locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);

const email = linkById('email');
const linkedin = linkById('linkedin');
---

<Section id="contact" eyebrow="06" title={dict.sections.contact}>
	<p class="text-fg-muted leading-relaxed mb-6 max-w-2xl">{dict.contact.intro}</p>
	<div class="flex flex-wrap gap-3">
		{email && (
			<Button href={email.url} variant="primary">
				{email.label} →
			</Button>
		)}
		{linkedin && (
			<Button href={linkedin.url} target="_blank" variant="outline">
				{linkedin.label} ↗
			</Button>
		)}
		{resume.links
			.filter((l) => !['email', 'linkedin'].includes(l.id))
			.map((link) => (
				<Button href={link.url} target="_blank" variant="ghost">
					{link.label} ↗
				</Button>
			))}
	</div>
</Section>
