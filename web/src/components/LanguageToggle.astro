---
import { alternateLocaleHref, t, type Locale } from '~/i18n';

interface Props {
	locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
const href = alternateLocaleHref(locale, Astro.url.pathname);
---

<a
	href={href}
	class="inline-flex items-center justify-center px-3 h-9 border border-border text-fg-muted hover:text-accent hover:border-accent font-mono text-xs transition-colors"
	title={dict.meta.langSwitchTitle}
	aria-label={dict.meta.langSwitchTitle}
>
	{dict.meta.langLabel}
</a>
