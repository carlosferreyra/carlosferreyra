{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*", "../data/resumes.json"],
	"exclude": ["dist"],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"~/*": ["src/*"],
			"@data/*": ["../data/*"]
		},
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false
	}
}
